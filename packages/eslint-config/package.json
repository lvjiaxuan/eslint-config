{
  "name": "@lvjiaxuan/eslint-config",
  "type": "module",
  "version": "1.13.0",
  "private": false,
  "description": "My personal ESLint config preset.",
  "author": "lvjiaxuan <471501748@qq.com> (https://github.com/lvjiaxuan)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lvjiaxuan/eslint-config"
  },
  "keywords": [
    "eslint-config",
    "oxlint"
  ],
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsdown --watch",
    "typegen": "pnpm exec tsx ./scripts/typegen.ts",
    "build": "pnpm run typegen && tsdown"
  },
  "peerDependencies": {
    "eslint": "catalog:",
    "eslint-plugin-oxlint": "catalog:"
  },
  "peerDependenciesMeta": {
    "@unocss/eslint-plugin": {
      "optional": true
    }
  },
  "dependencies": {
    "@antfu/eslint-config": "catalog:"
  },
  "inlinedDependencies": {
    "@eslint-community/eslint-utils": "4.9.1",
    "@typescript-eslint/scope-manager": "8.59.1",
    "@typescript-eslint/types": "8.59.1",
    "@typescript-eslint/utils": "8.59.1",
    "@typescript-eslint/visitor-keys": "8.59.1",
    "eslint-visitor-keys": [
      "3.4.3",
      "5.0.1"
    ]
  },
  "devDependencies": {
    "eslint-plugin-oxlint": "catalog:",
    "eslint-typegen": "^2.3.1",
    "tsx": "^4.21.0"
  }
}
