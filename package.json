{
  "name": "@lvjiaxuan/eslint-config-monorepo",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "nlx @eslint/config-inspector"
  },
  "devDependencies": {
    "@lvjiaxuan/eslint-config": "workspace:*",
    "@types/node": "catalog:types",
    "eslint": "catalog:",
    "simple-git-hooks": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "simple-git-hooks": {
    "pre-commit": [
      "npx lint-staged"
    ]
  },
  "lint-staged": {
    "*": "pnpm run oxlintf"
  }
}