{
  "name": "@lvjiaxuan/eslint-config-monorepo",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.0.9",
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "inspect": "npx @eslint/config-inspector",
    "prepare": "skills-npm && npx superpowers-zh@latest --tool qoder",
    "eslint": "eslint",
    "oxlint": "oxlint"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@lvjiaxuan/eslint-config": "workspace:*",
    "@types/node": "catalog:types",
    "eslint": "catalog:",
    "oxlint": "catalog:",
    "simple-git-hooks": "catalog:",
    "skills-npm": "catalog:ai-using",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "simple-git-hooks": {
    "pre-commit": []
  },
  "lint-staged": {
    "*": "pnpm run oxlintf"
  }
}
